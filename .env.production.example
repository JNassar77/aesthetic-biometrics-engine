# ─────────────────────────────────────────────────────────────────────────────
# Production environment template — Aesthetic Biometrics Engine
#
# Copy to `.env.production` (gitignored) and fill in, OR set these as Railway
# service variables (preferred — never commit real secrets). Operational config
# only; data-protection / retention policy (DSGVO) is handled separately before
# go-live, not in this file.
# ─────────────────────────────────────────────────────────────────────────────

# Enforces fail-closed auth: with ENVIRONMENT=production the API refuses to start
# serving the biometric endpoints unless API_KEYS is set (returns 503 otherwise).
ENVIRONMENT=production

# Comma-separated API keys accepted in the X-API-Key header. REQUIRED in production
# (no keys + production = fail closed). Generate strong random keys.
API_KEYS=replace-with-strong-random-key-1,replace-with-strong-random-key-2

# Supabase (AestheticBiometricsDB, eu-west-1). Use the service-role key on the
# backend so RLS service bypass works; never expose it to clients.
SUPABASE_URL=https://mbwteypkehrmeqzdzdph.supabase.co
SUPABASE_KEY=replace-with-supabase-service-role-key

# n8n webhook for downstream automation (optional; leave empty to disable).
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/aesthetic-analysis

# CORS — comma-separated allowed origins (your production frontend).
ALLOWED_ORIGINS=https://your-frontend.example.com

# Upload + analysis tuning.
MAX_IMAGE_SIZE_MB=10
MIN_FACE_CONFIDENCE=0.7

# Rate limiting — requests per minute per IP (0 disables).
RATE_LIMIT_RPM=60
