# ─────────────────────────────────────────────────────────────────────────────
# Engine runtime env for the Hetzner deploy. Copy to `deploy/hetzner/.env.production`
# (gitignored) and fill the two secrets. Operational config only — DSGVO / retention
# policy is handled separately before any real-patient go-live (Gate 0).
# ─────────────────────────────────────────────────────────────────────────────

# Fail-closed: with ENVIRONMENT=production the engine refuses to serve the biometric
# endpoints unless API_KEYS is set (returns 503 otherwise).
ENVIRONMENT=production

# X-API-Key value(s) the engine accepts (comma-separated). The Supabase Edge Function
# sends one of these. Generate a strong key:  openssl rand -hex 32
API_KEYS=

# AestheticBiometricsDB (mbwteypkehrmeqzdzdph, eu-west-1). Use the SERVICE-ROLE key
# (backend only — RLS bypass; NEVER expose to a browser). Supabase Dashboard →
# Project Settings → API → service_role secret.
SUPABASE_URL=https://mbwteypkehrmeqzdzdph.supabase.co
SUPABASE_KEY=

# The engine is only called server-to-server by the Edge Function (no browser talks to
# it directly), so no browser CORS origin is needed. Kept restrictive.
ALLOWED_ORIGINS=https://biometrics.novasyn.de

# Optional downstream automation (leave empty to disable).
N8N_WEBHOOK_URL=

# Upload + analysis tuning.
MAX_IMAGE_SIZE_MB=10
MIN_FACE_CONFIDENCE=0.7

# Rate limiting — requests per minute per IP (0 disables).
RATE_LIMIT_RPM=60
