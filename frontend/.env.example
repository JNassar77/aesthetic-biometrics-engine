# Copy to .env and fill in. Both values are public-safe (browser) values.

# Supabase Edge Function proxy base URL (no trailing slash).
# The app talks ONLY to this proxy — never to the engine directly.
VITE_ENGINE_PROXY_URL=https://mbwteypkehrmeqzdzdph.supabase.co/functions/v1/engine-proxy

# Supabase anon (publishable) key. Supabase -> Project Settings -> API.
# Public-safe: it only authenticates the caller to the proxy; the engine key stays server-side.
VITE_SUPABASE_ANON_KEY=replace-with-the-supabase-anon-key
